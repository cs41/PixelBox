etPixelColor(row * 8 + 2, p2);\n        strip.setPixelColor(row * 8 + 3, p3);\n        strip.setPixelColor(row * 8 + 4, p4);\n        strip.setPixelColor(row * 8 + 5, p5);\n        strip.setPixelColor(row * 8 + 6, p6);\n        strip.setPixelColor(row * 8 + 7, p7);\n    }\n    \n\n    /**\n     * \n     */\n\n\n\n\n"}]},{"timestamp":1778115358237,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":1279,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"!UT4il|?cX.pE$N6NmPd\">strip</variable></variables><block type=\"pxt-on-start\" x=\"405\" y=\"-15\"><statement name=\"HANDLER\"><block type=\"variables_set\"><field name=\"VAR\" id=\"!UT4il|?cX.pE$N6NmPd\">strip</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"neopixel_create\"><field name=\"pin\">DigitalPin.P1</field><field name=\"mode\">NeoPixelMode.RGB</field><value name=\"numleds\"><shadow type=\"math_number\"><field name=\"NUM\">64</field></shadow></value></block></value><next><block type=\"neopixel_show\"><value name=\"strip\"><block type=\"variables_get\"><field name=\"VAR\" id=\"!UT4il|?cX.pE$N6NmPd\">strip</field></block></value></block></next></block></statement></block></xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":65,"length1":54,"diffs":[[1,"strip.show()\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":322,"length1":35,"diffs":[[1,"    \"preferredEditor\": \"tsprj\"\n"]]}]},{"type":"edited","filename":"custom.ts","patch":[{"start1":119,"length1":99,"diffs":[[1,""]]},{"start1":592,"length1":3,"diffs":[[1,""]]},{"start1":676,"length1":701,"diffs":[[1,""]]},{"start1":1964,"length1":373,"diffs":[[1,"    export function varbar2(row: number, p0: number, p1: number, p2: number, p3: number, p4: number, p5: number, p6: number, p7: number): void {\n        strip.setPixelColor(row * 8 + 0, p0);\n        strip.setPixe